# AroundU Backend – Production Environment Template

# Application
ENVIRONMENT=production
PROJECT_NAME="AroundU API"

# Security (Required: Generate a 32+ character secure key)
SECRET_KEY="85bd5fb2e27325257f1eca1b1712d2f75af06b9aef14537ddb98d925b44627cf"

# Database
DATABASE_URL=postgresql://user:password@db_host:5432/db_name
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Cloudinary (Required for image storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis (Required for Rate Limiting)
REDIS_URL=redis://redis_host:6379/0
ENABLE_REDIS=true

# AI Service (Optional)
AI_SERVICE_URL=http://ai_service:8001

# Logging
LOG_LEVEL=INFO
